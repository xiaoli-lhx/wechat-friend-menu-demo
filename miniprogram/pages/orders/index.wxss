.page-head {
  margin-bottom: 22rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
}

.state-card {
  padding: 42rpx 28rpx;
  text-align: center;
  color: var(--text-secondary);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  line-height: 1.7;
}

.order-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffafc 100%);
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-time {
  display: block;
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
}

.order-user {
  display: block;
  margin-top: 8rpx;
  color: #b79aae;
  font-size: 22rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-submitted {
  background: #ffe8f1;
  color: #ff4f94;
}

.status-done {
  background: #e8fff4;
  color: #2ca26b;
}

.order-summary {
  display: block;
  margin-top: 18rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.7;
}

.order-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
}

.remark-text {
  flex: 1;
  min-width: 0;
  color: #b79aae;
  font-size: 22rpx;
  line-height: 1.6;
}

.order-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.order-price {
  color: var(--accent-deep);
  font-size: 32rpx;
  font-weight: 700;
}

.complete-btn {
  min-width: 132rpx;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff0f6;
  color: var(--accent-deep);
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 110, 168, 0.15);
  box-sizing: border-box;
}

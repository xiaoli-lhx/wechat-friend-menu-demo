.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 28rpx;
  background: linear-gradient(180deg, #fffafc 0%, #fff2f7 100%);
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: #ffe7f0;
}

.nickname {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.uid-text {
  margin-top: 10rpx;
  color: #b79aae;
  font-size: 22rpx;
  text-align: center;
  word-break: break-all;
}

.name-editor {
  width: 100%;
  margin-top: 22rpx;
}

.name-input {
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fff7fb;
  color: var(--text-main);
  font-size: 26rpx;
  box-sizing: border-box;
}

.save-btn {
  margin-top: 14rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd6e8 0%, #ffbddb 100%);
  color: #9d486f;
  font-size: 24rpx;
  font-weight: 700;
}

.save-btn::after {
  border: 0;
}

.light-btn {
  margin-top: 22rpx;
  padding: 0 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #fff0f6;
  color: var(--accent-deep);
  font-size: 24rpx;
}

.light-btn::after {
  border: 0;
}

.stats-card,
.quote-card {
  margin-top: 20rpx;
  padding: 28rpx 26rpx;
}

.stats-label,
.quote-title {
  display: block;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.stats-value {
  display: block;
  margin-top: 14rpx;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--accent-deep);
}

.stats-tip,
.quote-text {
  display: block;
  margin-top: 14rpx;
  color: var(--text-main);
  font-size: 26rpx;
  line-height: 1.8;
}

.primary-btn {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff87b7 0%, #ff5f9d 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-btn::after {
  border: 0;
}

<view class="page">
  <view class="hero card">
    <image class="shop-avatar" src="{{shopInfo.avatar}}" mode="aspectFill"></image>
    <view class="hero-body">
      <view class="hero-top">
        <text class="shop-name">{{shopInfo.name}}</text>
        <text class="pill">{{shopInfo.tagline}}</text>
      </view>
      <text class="shop-notice">{{shopInfo.notice}}</text>
      <view class="hero-actions">
        <button class="mini-btn ghost-btn" bindtap="handleRandomPick">随机选一个</button>
        <text class="mode-text">{{modeText}}</text>
      </view>
    </view>
  </view>

  <view class="remark-card card">
    <view class="section-title">今天想怎么点</view>
    <input
      class="remark-input"
      placeholder="比如：少冰、帮我选最可爱的那份"
      maxlength="40"
      value="{{remark}}"
      bindinput="handleRemarkInput"
    />
  </view>

  <view class="menu-layout">
    <scroll-view class="category-panel card" scroll-y="true">
      <view
        wx:for="{{categories}}"
        wx:key="_id"
        class="category-item {{item._id === currentCategoryId ? 'is-active' : ''}}"
        data-id="{{item._id}}"
        bindtap="handleCategoryTap"
      >
        <text class="category-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <scroll-view class="goods-panel" scroll-y="true">
      <view wx:if="{{loading}}" class="state-box card">
        <text>菜单正在摆盘，请稍等一下下。</text>
      </view>

      <view wx:elif="{{!currentItems.length}}" class="state-box card">
        <text>这个分类暂时空空的，像刚被朋友扫荡过。</text>
      </view>

      <block wx:else>
        <view
          wx:for="{{currentItems}}"
          wx:key="_id"
          class="goods-card card"
        >
          <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="goods-body">
            <view class="goods-head">
              <view class="goods-title-wrap">
                <text class="goods-name">{{item.name}}</text>
                <text wx:if="{{item.badgeText}}" class="goods-badge">{{item.badgeText}}</text>
                <text wx:if="{{item.specGroups && item.specGroups.length}}" class="goods-spec-preview">点 + 先选糖度和冰度</text>
              </view>
              <view class="goods-action">
                <view
                  wx:if="{{!item.specGroups || !item.specGroups.length}}"
                  class="goods-simple-stepper"
                >
                  <view
                    wx:if="{{item.cartCount > 0}}"
                    class="step-btn is-minus"
                    data-id="{{item._id}}"
                    bindtap="handleMinusItem"
                  >
                    -
                  </view>
                  <text wx:if="{{item.cartCount > 0}}" class="step-count">{{item.cartCount}}</text>
                </view>
                <view class="add-btn" data-id="{{item._id}}" bindtap="handleAddItem">+</view>
              </view>
            </view>
            <text class="goods-desc">{{item.desc}}</text>
            <view class="goods-meta">
              <text class="sales-text">月销 {{item.monthlySales}}</text>
              <text class="price-text">¥{{item.price}}</text>
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <view wx:if="{{specPopupVisible}}" class="cart-mask" bindtap="closeSpecPopup"></view>

  <view wx:if="{{specPopupVisible}}" class="spec-popup card">
    <view class="spec-popup-head">
      <view>
        <text class="spec-popup-title">{{specDraftItem.name}}</text>
        <text wx:if="{{specDraftItem.badgeText}}" class="goods-badge cart-badge-mini">{{specDraftItem.badgeText}}</text>
      </view>
      <view class="close-btn" bindtap="closeSpecPopup">收起</view>
    </view>

    <text class="spec-popup-desc">{{specDraftItem.desc}}</text>

    <view class="spec-groups">
      <view
        wx:for="{{specDraftItem.specGroups}}"
        wx:for-item="group"
        wx:for-index="groupIndex"
        wx:key="id"
        class="cart-spec-group"
      >
        <text class="cart-spec-label">{{group.name}}</text>
        <view class="cart-spec-options">
          <text
            wx:for="{{group.options}}"
            wx:for-item="option"
            wx:key="*this"
            class="cart-spec-option {{specDraftSelections[groupIndex].value === option ? 'is-active' : ''}}"
            data-group-id="{{group.id}}"
            data-value="{{option}}"
            bindtap="handleDraftSpecSelect"
          >
            {{option}}
          </text>
        </view>
      </view>
    </view>

    <button class="spec-confirm-btn" bindtap="handleConfirmSpec">选好了，加入购物车</button>
  </view>

  <view wx:if="{{cartVisible}}" class="cart-mask" bindtap="handleCloseCart"></view>

  <view wx:if="{{cartVisible}}" class="cart-popup card">
    <view class="cart-popup-head">
      <text class="cart-popup-title">购物车小剧场</text>
      <view class="cart-popup-actions">
        <view class="clear-btn" bindtap="handleClearCart">清空</view>
        <view class="close-btn" bindtap="handleCloseCart">收起</view>
      </view>
    </view>

    <scroll-view class="cart-popup-list" scroll-y="true">
      <view wx:for="{{cartItems}}" wx:for-item="cartItem" wx:key="cartKey" class="cart-popup-item">
        <view class="cart-popup-main">
          <view class="cart-popup-name-wrap">
            <text class="cart-popup-name">{{cartItem.name}}</text>
            <text wx:if="{{cartItem.badgeText}}" class="goods-badge cart-badge-mini">{{cartItem.badgeText}}</text>
          </view>
          <text class="cart-popup-price">¥{{cartItem.price}}</text>
        </view>
        <view class="cart-popup-bottom">
          <view class="cart-popup-copy">
            <text class="cart-popup-desc">{{cartItem.desc}}</text>
            <text wx:if="{{cartItem.specSummary}}" class="cart-spec-summary">{{cartItem.specSummary}}</text>
          </view>
          <view class="cart-popup-stepper">
            <view class="step-btn is-minus" data-cart-key="{{cartItem.cartKey}}" bindtap="handleMinusItem">-</view>
            <text class="step-count">{{cartItem.count}}</text>
            <view class="step-btn is-plus" data-cart-key="{{cartItem.cartKey}}" bindtap="handleAddItem">+</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar">
    <view class="cart-info" bindtap="handleToggleCart">
      <view class="cart-badge">{{cartCount}}</view>
      <view class="cart-copy">
        <text class="cart-total">合计 ¥{{cartTotalPrice}}</text>
        <text class="cart-tip">{{cartCount ? '已经选了 ' + cartCount + ' 份快乐，点这里展开购物车' : '已经选了 0 份快乐'}}</text>
      </view>
    </view>
    <button
      class="submit-btn"
      disabled="{{!cartCount || submitting}}"
      catchtap="handleSubmitOrder"
      bindtap="handleSubmitOrder"
    >
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
